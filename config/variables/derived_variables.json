{
  "note": "Phase 3 domain-driven seed registry. This replaces the legacy A-J draft; full variable expansion will be generated during Phase 3 implementation.",
  "variables": [
    {
      "name": "close_hfq",
      "label_zh": "后复权收盘价",
      "table": "derived_daily_spine",
      "module": "daily_spine",
      "category": "adjusted_price",
      "tier": "p0",
      "dtype": "DOUBLE",
      "unit": "yuan",
      "frequency": "daily",
      "grain": ["ts_code", "trade_date"],
      "source_type": "derived",
      "dependencies": ["stock_daily.close", "stock_adj_factor.adj_factor"],
      "formula_ref": "stock_daily.close * stock_adj_factor.adj_factor",
      "price_basis": "hfq",
      "point_in_time": true,
      "min_history": 1,
      "read_window": 20,
      "write_window": 10,
      "missing_policy": "required",
      "validation": {"min_value": 0, "constant_allowed": false}
    },
    {
      "name": "log_ret_1",
      "label_zh": "1日对数收益率",
      "table": "derived_daily_spine",
      "module": "daily_spine",
      "category": "base_return",
      "tier": "p0",
      "dtype": "DOUBLE",
      "unit": "ratio",
      "frequency": "daily",
      "grain": ["ts_code", "trade_date"],
      "source_type": "derived",
      "dependencies": ["close_hfq"],
      "formula_ref": "ln(close_hfq / lag(close_hfq, 1))",
      "price_basis": "hfq",
      "point_in_time": true,
      "min_history": 2,
      "read_window": 20,
      "write_window": 10,
      "missing_policy": "initial_window_null",
      "validation": {"constant_allowed": false}
    },
    {
      "name": "rsi_14",
      "label_zh": "14日相对强弱指标",
      "table": "derived_price_technical",
      "module": "price_technical",
      "category": "oscillator",
      "tier": "core",
      "dtype": "DOUBLE",
      "unit": "ratio",
      "frequency": "daily",
      "grain": ["ts_code", "trade_date"],
      "source_type": "derived",
      "dependencies": ["close_hfq"],
      "formula_ref": "indicators.rsi",
      "params": {"window": 14},
      "price_basis": "hfq",
      "point_in_time": true,
      "min_history": 14,
      "read_window": 80,
      "write_window": 10,
      "missing_policy": "initial_window_null",
      "validation": {"min_non_null_rate": 0.95, "constant_allowed": false, "range": [0, 100]}
    },
    {
      "name": "volume_ma_20",
      "label_zh": "20日成交量均线",
      "table": "derived_volume_liquidity",
      "module": "volume_liquidity",
      "category": "volume_trend",
      "tier": "core",
      "dtype": "DOUBLE",
      "unit": "lot",
      "frequency": "daily",
      "grain": ["ts_code", "trade_date"],
      "source_type": "derived",
      "dependencies": ["stock_daily.volume"],
      "formula_ref": "rolling_mean(volume, 20)",
      "params": {"window": 20},
      "price_basis": "not_price",
      "point_in_time": true,
      "min_history": 20,
      "read_window": 80,
      "write_window": 10,
      "missing_policy": "initial_window_null",
      "validation": {"min_non_null_rate": 0.95, "constant_allowed": false}
    },
    {
      "name": "ret_20",
      "label_zh": "20日收益率",
      "table": "derived_return_momentum",
      "module": "return_momentum",
      "category": "multi_period_return",
      "tier": "core",
      "dtype": "DOUBLE",
      "unit": "ratio",
      "frequency": "daily",
      "grain": ["ts_code", "trade_date"],
      "source_type": "derived",
      "dependencies": ["close_hfq"],
      "formula_ref": "close_hfq / lag(close_hfq, 20) - 1",
      "params": {"window": 20},
      "price_basis": "hfq",
      "point_in_time": true,
      "min_history": 21,
      "read_window": 80,
      "write_window": 10,
      "missing_policy": "initial_window_null",
      "validation": {"constant_allowed": false}
    },
    {
      "name": "hv_60",
      "label_zh": "60日历史波动率",
      "table": "derived_volatility_risk",
      "module": "volatility_risk",
      "category": "historical_volatility",
      "tier": "core",
      "dtype": "DOUBLE",
      "unit": "percent",
      "frequency": "daily",
      "grain": ["ts_code", "trade_date"],
      "source_type": "derived",
      "dependencies": ["log_ret_1"],
      "formula_ref": "stddev(log_ret_1, 60) * sqrt(242)",
      "params": {"window": 60, "annual_days": 242},
      "price_basis": "hfq",
      "point_in_time": true,
      "min_history": 60,
      "read_window": 160,
      "write_window": 10,
      "missing_policy": "initial_window_null",
      "validation": {"min_non_null_rate": 0.9, "min_value": 0, "constant_allowed": false}
    },
