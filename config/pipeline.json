  "stock_scope": {
    "include_exchanges": ["SSE", "SZSE", "BSE"],
    "include_markets": ["主板", "创业板", "科创板", "北交所"],
    "include_list_status": ["L", "D", "P"],
    "daily_update_status": ["L"]
  }
}
