{
  "daily_light": {
    "schedule_local_time": "20:00",
    "timezone": "Asia/Shanghai",
    "command": ".venv-wsl/bin/stock-maintain daily-light --as-of-date <YYYY-MM-DD> --output-prefix <run_id>",
    "follow_up_command": ".venv-wsl/bin/stock-maintain summarize-run --mode daily --run-id <run_id>",
    "report_format": "markdown",
    "expected_latest_trade_date_delays": [
      "margin_detail",
      "northbound_holding"
    ],
    "notes": "Daily-light runs at 20:00 to cover evening T+0 Tushare APIs. Latest-trade-date gaps in expected_latest_trade_date_delays are treated as T+1 source delay when validate-daily marks them as expected delay."
  },
  "daily_full": {
    "schedule_local_time": "20:30",
    "timezone": "Asia/Shanghai",
    "command": ".venv-wsl/bin/stock-maintain daily-full --as-of-date <YYYY-MM-DD> --reload-trade-days 1 --output-prefix <run_id>",
    "repair_command": ".venv-wsl/bin/stock-maintain daily-full --as-of-date <YYYY-MM-DD> --reload-trade-days <N> --refresh-weekly-snapshot --output-prefix <run_id>",
    "follow_up_command": ".venv-wsl/bin/stock-maintain summarize-run --mode daily --run-id <run_id>",
    "report_format": "markdown",
    "notes": "Daily-full force reloads the target trade-date window for daily source tables and rebuilds derived features. Use it when source data arrived late or daily-light skipped because no missing trade dates were detected."
  },
  "weekly_full": {
    "command": ".venv-wsl/bin/stock-maintain weekly-full --as-of-date <YYYY-MM-DD> --auto-create-missing-snapshot --output-prefix <run_id>",
    "follow_up_command": ".venv-wsl/bin/stock-maintain summarize-run --mode weekly --run-id <run_id>",
    "report_format": "markdown"
  }
}
